# configuration hadoop injectee dans tous les conteneurs du cluster
# le prefixe indique le fichier xml cible et les underscores deviennent des points dans le nom de la propriete

CORE_CONF_fs_defaultFS=hdfs://namenode:9000
CORE_CONF_hadoop_http_staticuser_user=root

# je veux que chaque bloc soit copie sur les trois datanodes
HDFS_CONF_dfs_replication=3

# mes fichiers font environ 76 Ko et la taille de bloc par defaut est de 128 Mo
# chaque fichier tiendrait donc dans un seul bloc et je ne verrais aucun decoupage
# je descends la taille de bloc a 32 Ko pour observer un vrai decoupage en plusieurs blocs
HDFS_CONF_dfs_namenode_fs___limits_min___block___size=32768
HDFS_CONF_dfs_blocksize=32768

# je desactive les permissions pour simplifier les echanges entre spark et hdfs dans le cadre du tp
HDFS_CONF_dfs_permissions_enabled=false
HDFS_CONF_dfs_webhdfs_enabled=true

# les conteneurs se joignent par leur nom de service donc je force l'usage des hostnames
HDFS_CONF_dfs_client_use_datanode_hostname=true
HDFS_CONF_dfs_datanode_use_datanode_hostname=true
HDFS_CONF_dfs_namenode_datanode_registration_ip___hostname___check=false
